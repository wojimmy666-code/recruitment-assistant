{
    "manifest_version":  3,
    "name":  "Recruitment Assistant Bridge",
    "version":  "0.3.4",
    "description":  "Bridge logged-in BOSS pages to the local recruitment assistant.",
    "action":  {
                   "default_popup":  "popup.html",
                   "default_title":  "Recruitment Assistant"
               },
    "background":  {
                       "service_worker":  "background.js"
                   },
    "permissions":  [
                        "activeTab",
                        "tabs",
                        "scripting",
                        "webNavigation",
                        "alarms",
                        "storage"
                    ],
    "host_permissions":  [
                             "https://www.zhipin.com/*",
                             "http://localhost:3000/*"
                         ],
    "content_scripts":  [
                            {
                                "matches":  [
                                                "https://www.zhipin.com/*"
                                            ],
                                "js":  [
                                           "content-script.js"
                                       ],
                                "run_at":  "document_idle",
                                "all_frames":  true
                            }
                        ]
}
